# Copy this file to .env and fill your values.

# n8n incoming webhooks (set these after importing the n8n workflow)
N8N_CAPTCHA_IN_WEBHOOK_URL=http://localhost:5678/webhook/captcha-in
N8N_BOOKING_STATUS_WEBHOOK_URL=http://localhost:5678/webhook/booking-status

# Telegram is handled by n8n (not Python) — no bot token needed here.

# IRCTC credentials (OPTIONAL: keep empty if you prefer manual entry)
IRCTC_USERNAME=
IRCTC_PASSWORD=

# Chrome options
HEADLESS=false
